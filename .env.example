# ============================================
# Agent System - Environment Configuration
# ============================================

# -----------------------------------------
# REQUIRED: LLM API Configuration
# -----------------------------------------
# OpenAI compatible API key
LLM_API_KEY=your_api_key_here

# Base URL for the API endpoint (e.g., https://api.openai.com/v1)
LLM_BASE_URL=https://api.example.com/v1

# Model name to use (e.g., gpt-4o, etc.)
LLM_MODEL=your_model_name_here

# -----------------------------------------
# Bocha Web Search API
# -----------------------------------------
# API key for Bocha AI web search service
BOCHA_API_KEY=your_bocha_api_key_here

# -----------------------------------------
# Rate Limiting & Retry Configuration
# -----------------------------------------
# Requests per minute (0 = disabled, default 450 with buffer below typical 500 limit)
# Burst capacity automatically uses max_concurrent_agents value
LLM_RATE_LIMIT_RPM=450
# Maximum retry attempts for failed API calls (1 = no retry)
LLM_RETRY_MAX_ATTEMPTS=3
# Base delay in seconds for exponential backoff between retries
LLM_RETRY_BASE_DELAY=1.0

# -----------------------------------------
# Multi-Provider Configuration
# -----------------------------------------
# Legacy single-key config above still works and is used as default when profiles are not selected.
# JSON array of provider profiles for multi-provider routing and load balancing.
# Each profile: {"name":"...", "api_key":"...", "base_url":"...", "model":"...", "rpm_limit":N, "tpm_limit":N}
# When set, overrides individual LLM_API_KEY/BASE_URL/MODEL for profile selection.
# Tip: Set RPM/TPM to ~80% of actual provider quota to leave headroom.
# LLM_PROVIDER_PROFILES=[{"name":"aliyun","api_key":"sk-xxx","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","model":"qwen-plus","rpm_limit":50,"tpm_limit":30000},{"name":"minimax","api_key":"sk-yyy","base_url":"https://api.minimax.chat/v1","model":"MiniMax-Text-01","rpm_limit":40,"tpm_limit":25000}]

# -----------------------------------------
# Lane Concurrency
# -----------------------------------------
LLM_MAIN_LANE_CONCURRENCY=4
LLM_SUBAGENT_LANE_CONCURRENCY=8

# -----------------------------------------
# Adaptive Pacing
# -----------------------------------------
LLM_PACING_ENABLED=true
LLM_PACING_MIN_INTERVAL_MS=500

# -----------------------------------------
# Key Rotation & Fallback
# -----------------------------------------
LLM_KEY_ROTATION_ENABLED=true
LLM_FALLBACK_ENABLED=true

# -----------------------------------------
# Cooldown
# -----------------------------------------
LLM_COOLDOWN_INITIAL_MS=30000
LLM_COOLDOWN_MAX_MS=300000

